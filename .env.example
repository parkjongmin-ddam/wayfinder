# Wayfinder / langconnect_agent environment
# Provider for the LLM factory: "mock" (default, offline, no keys), "anthropic", or "openai".
LLM_PROVIDER=mock

# Optional model overrides (defaults live in langconnect_agent.config.Config):
# ROUTER_MODEL=claude-haiku-4-5
# ANSWER_MODEL=claude-opus-4-8
# TOP_K=5
# ROUTE_DEFAULT=semantic
# GRADE_THRESHOLD=0.5
# MAX_FALLBACKS=1

# API keys — only needed when LLM_PROVIDER is set to a real provider.
# ANTHROPIC_API_KEY=sk-ant-...
# OPENAI_API_KEY=sk-...
# TAVILY_API_KEY=tvly-...

# pgvector (Phase 1 parity — real langconnect-v2 backend). pip install -e ".[pgvector]"
# PGVECTOR_CONNINFO=postgresql://user:pass@host:5432/dbname
# PGVECTOR_TABLE=langconnect_embeddings
# PGVECTOR_ID_COLUMN=id
# PGVECTOR_CONTENT_COLUMN=content
# PGVECTOR_EMBEDDING_COLUMN=embedding
# PGVECTOR_METADATA_COLUMN=metadata

# LangSmith tracing/observability (Phase 2 gate item). pip install -e ".[langsmith]"
# LANGSMITH_TRACING=true
# LANGSMITH_API_KEY=lsv2_...
# LANGSMITH_PROJECT=wayfinder
# Non-US regions: set the API host to match the region your KEY was issued in
# (the app host and API host differ — note the "api"). Without this the SDK
# defaults to US and traces won't appear in your org.
#   US   : https://api.smith.langchain.com  (default; omit)
#   EU   : https://eu.api.smith.langchain.com
#   APAC : https://apac.api.smith.langchain.com
# LANGSMITH_ENDPOINT=https://apac.api.smith.langchain.com
