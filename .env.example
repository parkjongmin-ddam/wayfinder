# Wayfinder / langconnect_agent environment
# Provider for the LLM factory: "mock" (default, offline, no keys), "anthropic",
# "openai", or "ollama" (local models, no API key). pip install -e ".[ollama]".
LLM_PROVIDER=mock

# Optional model overrides (defaults live in langconnect_agent.config.Config).
# Defaults are provider-aware: hosted -> Claude names below; ollama -> the ollama
# tags below (a fast 3B router that fits 6 GB VRAM 100% on-GPU + an 8B answerer).
# ROUTER_MODEL=claude-haiku-4-5
# ANSWER_MODEL=claude-opus-4-8
# ollama defaults:
# ROUTER_MODEL=qwen2.5:3b
# ANSWER_MODEL=llama3.1:8b
# Sampling temperature (0.0 = deterministic routing/grading/answers, reproducible traces).
# ROUTER_TEMPERATURE=0.0
# ANSWER_TEMPERATURE=0.0
# TOP_K=5
# ROUTE_DEFAULT=semantic
# GRADE_THRESHOLD=0.5
# MAX_FALLBACKS=1

# Local Ollama server (LLM_PROVIDER=ollama). Start it with `ollama serve` and
# `ollama pull qwen2.5:3b llama3.1:8b`. Defaults to localhost:11434.
# OLLAMA_BASE_URL=http://localhost:11434

# API keys — only needed when LLM_PROVIDER is set to a real hosted provider
# ("ollama" needs none).
# ANTHROPIC_API_KEY=sk-ant-...
# OPENAI_API_KEY=sk-...
# TAVILY_API_KEY=tvly-...

# pgvector (Phase 1 parity — routes A/B).
#   hosted embeddings: pip install -e ".[openai,pgvector]"
#   local  embeddings: pip install -e ".[ollama,pgvector]"  (ollama pull nomic-embed-text)
# RETRIEVER_PROVIDER selects the retriever: auto (pgvector if CONNINFO set, else stub) | stub | langconnect
# RETRIEVER_PROVIDER=auto
# EMBEDDING_PROVIDER selects the embedder: auto (follows LLM_PROVIDER: ollama->local, else openai) | openai | ollama
# EMBEDDING_PROVIDER=auto
# EMBEDDING_MODEL: defaults per provider — openai=text-embedding-3-small, ollama=nomic-embed-text
# EMBEDDING_MODEL=nomic-embed-text
# Local Docker pgvector: docker run -d --name wayfinder-pgvector -e POSTGRES_PASSWORD=wayfinder \
#   -e POSTGRES_DB=wayfinder -p 5433:5432 pgvector/pgvector:pg17
# PGVECTOR_CONNINFO=postgresql://postgres:wayfinder@localhost:5433/wayfinder
# PGVECTOR_CONNINFO=postgresql://user:pass@host:5432/dbname
# PGVECTOR_TABLE=langconnect_embeddings
# PGVECTOR_ID_COLUMN=id
# PGVECTOR_CONTENT_COLUMN=content
# PGVECTOR_EMBEDDING_COLUMN=embedding
# PGVECTOR_METADATA_COLUMN=metadata

# Multi-agent orchestration (Step 4) — additive orchestrator graph.
# AGENT_MODE selects the served agent: single (graph.py) | multi (orchestrator.py)
# AGENT_MODE=multi
# MAX_AGENT_STEPS=4    # supervisor step cap (guarantees termination)
# REWRITE_COUNT=2      # query reformulations the retrieval agent adds

# Verification harness — post-answer faithfulness gate + 1-hop regen loop.
# FAITHFULNESS selects the metric: (unset)=offline lexical proxy | ragas (needs a real LLM)
# FAITHFULNESS=ragas
# FAITHFULNESS_THRESHOLD=0.35   # low: lexical proxy underestimates paraphrase; raise for RAGAS
# MAX_VERIFY_RETRIES=1

# LangSmith tracing/observability (Phase 2 gate item). pip install -e ".[langsmith]"
# LANGSMITH_TRACING=true
# LANGSMITH_API_KEY=lsv2_...
# LANGSMITH_PROJECT=wayfinder
# Non-US regions: set the API host to match the region your KEY was issued in
# (the app host and API host differ — note the "api"). Without this the SDK
# defaults to US and traces won't appear in your org.
#   US   : https://api.smith.langchain.com  (default; omit)
#   EU   : https://eu.api.smith.langchain.com
#   APAC : https://apac.api.smith.langchain.com
# LANGSMITH_ENDPOINT=https://apac.api.smith.langchain.com
